---
export interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;

const sections = [
  { href: '/',                label: '🦜 物種概述',  subtitle: '' },
  { href: '/selecting-chicks', label: '🥚 幼鳥挑選',  subtitle: '健康檢查表、性別判斷' },
  { href: '/hand-feeding',     label: '🍼 手養方式',  subtitle: '成長時程、餵食步驟、保溫' },
  { href: '/taming',           label: '🤝 親人訓練',  subtitle: '上手訓練、正向強化' },
  { href: '/training-skills',  label: '🎯 技能訓練',  subtitle: '響片目標、特技召回' },
  { href: '/health-check',     label: '🏥 健康檢查',  subtitle: '疾病徵兆、急救照護' },
  { href: '/daily-care',       label: '🏠 日常飼養',  subtitle: '飲食、籠具、環境安全' },
  { href: '/behavior',         label: '🧠 行為特質',  subtitle: '飼養提醒、Q&A' },
];
---

<aside class="glass-sidebar">
  <div class="sidebar-header">📖 目錄</div>
  <nav>
    <ul class="sidebar-list">
      {sections.map(s => (
        <li class="sidebar-item">
          <a
            href={s.href}
            class:list={{ 'sidebar-link': true, active: currentPath === s.href }}
          >
            <span class="sidebar-label">{s.label}</span>
            {s.subtitle && <span class="sidebar-sub">{s.subtitle}</span>}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</aside>

<style>
  .glass-sidebar {
    width: 230px;
    flex-shrink: 0;
    position: sticky;
    top: calc(var(--header-height) + 20px);
    align-self: flex-start;
    max-height: calc(100vh - var(--header-height) - 40px);
    overflow-y: auto;
    background: var(--glass-bg);
    backdrop-filter: blur(16px) saturate(1.3);
    -webkit-backdrop-filter: blur(16px) saturate(1.3);
    border-radius: var(--radius-lg);
    border: 1px solid var(--glass-border);
    box-shadow: var(--glass-shadow);
    padding: 0.5rem;
  }

  .glass-sidebar::-webkit-scrollbar { width: 4px; }
  .glass-sidebar::-webkit-scrollbar-track { background: transparent; }
  .glass-sidebar::-webkit-scrollbar-thumb { background: var(--glass-border); border-radius: 4px; }

  .sidebar-header {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--text-tertiary);
    padding: 0.7rem 0.85rem 0.5rem;
  }

  .sidebar-list { list-style: none; padding: 0; }
  .sidebar-item { margin-bottom: 0.15rem; }

  .sidebar-link {
    display: flex;
    flex-direction: column;
    padding: 0.55rem 0.85rem;
    border-radius: var(--radius-sm);
    color: var(--text-secondary);
    font-size: 0.88rem;
    font-weight: 500;
    transition: all 0.18s ease;
    text-decoration: none;
    position: relative;
    overflow: hidden;
  }

  .sidebar-link::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 3px;
    background: var(--accent-gradient);
    border-radius: 0 3px 3px 0;
    transform: scaleY(0);
    transition: transform 0.18s ease;
  }

  .sidebar-link:hover {
    color: var(--coral);
    background: rgba(232,99,58,0.04);
    text-decoration: none;
  }

  .sidebar-link:hover::before { transform: scaleY(0.6); }

  .sidebar-link.active {
    color: var(--coral-dark);
    background: rgba(232,99,58,0.06);
    border: 1px solid rgba(232,99,58,0.12);
  }

  .sidebar-link.active::before { transform: scaleY(1); }

  .sidebar-sub {
    font-size: 0.7rem;
    font-weight: 400;
    color: var(--text-tertiary);
    margin-top: 0.1rem;
  }

  @media (max-width: 768px) {
    .glass-sidebar { display: none; }
  }
</style>
