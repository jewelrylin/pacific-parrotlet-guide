---
import Header from '../components/Header.astro';
import Sidebar from '../components/Sidebar.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

export interface Props {
  title: string;
  description?: string;
  currentPath?: string;
  pageImage?: string;
  pageImageAlt?: string;
}

const { title, description, currentPath = '/', pageImage, pageImageAlt } = Astro.props;
---

<!doctype html>
<html lang="zh-TW">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | 太平洋鸚鵡飼養指南</title>
    {description && <meta name="description" content={description} />}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://upload.wikimedia.org" />
  </head>
  <body>
    <!-- Glass shard particles for navigation transition -->
    <div class="glass-shard" aria-hidden="true"></div>
    <div class="glass-shard" aria-hidden="true"></div>
    <div class="glass-shard" aria-hidden="true"></div>
    <div class="glass-shard" aria-hidden="true"></div>
    <div class="glass-shard" aria-hidden="true"></div>
    <div class="glass-shard" aria-hidden="true"></div>
    <div class="glass-shard" aria-hidden="true"></div>
    <div class="glass-shard" aria-hidden="true"></div>
    <div class="glass-shard" aria-hidden="true"></div>
    <div class="glass-shard" aria-hidden="true"></div>

    <div class="layout-wrapper">
      <Header />
      <div class="content-wrapper">
        <Sidebar currentPath={currentPath} />
        <main class="main-content">
          <article>
            {pageImage && (
              <div class="page-hero-image">
                <img src={pageImage} alt={pageImageAlt || title} loading="lazy" />
              </div>
            )}
            <slot />
          </article>
        </main>
      </div>
      <Footer />
    </div>

    <script>
      document.addEventListener('astro:page-load', () => {
        document.querySelectorAll('a[href]').forEach(link => {
          link.addEventListener('click', (e) => {
            const href = link.getAttribute('href');
            if (href?.startsWith('/') && !href.startsWith('//') && !e.metaKey && !e.ctrlKey) {
              const shards = document.querySelectorAll('.glass-shard');
              shards.forEach((shard, i) => {
                shard.style.left = (40 + Math.random() * 20) + '%';
                shard.style.top = (35 + Math.random() * 30) + '%';
                shard.style.animation = 'none';
                shard.offsetWidth;
                shard.style.animation = `shard-fly 0.3s ease-out ${i * 0.015}s forwards`;
              });
            }
          });
        });
      });
    </script>
  </body>
</html>
